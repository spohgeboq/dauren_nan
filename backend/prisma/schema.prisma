generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  BAKER
  DRIVER
  CASHIER
  CLIENT
}

enum EmployeeStatus {
  ACTIVE
  FIRED
}

enum OrderStatus {
  NEW
  ACCEPTED
  CANCELLED
}

enum RouteStatus {
  BUILDING
  IN_TRANSIT
  COMPLETED
}

enum PointStatus {
  PENDING
  DELIVERED
  CANCELLED
}

enum PurchaseStatus {
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum VehicleStatus {
  ACTIVE
  REPAIR
}

enum BatchType {
  READY
  DEFECT
}

enum PaymentMethod {
  CASH
  KASPI
}

enum ExpenseCategory {
  SALARY
  FUEL
  RENT
  UTILITIES
  MAINTENANCE
  INGREDIENTS
  INVENTORY_LOSS
  OTHER
}

enum AdjustmentType {
  AUDIT
  WRITE_OFF
}

enum IncomeSource {
  POS
  DELIVERY
  DEBT_PAYMENT
  MANUAL
}

enum BatchStatus {
  IN_PROGRESS
  COMPLETED
}

enum DeliveryOrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Users / Employees ──────────────────────────────────

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  passwordHash String
  name         String?
  phone        String?
  login        String?         @unique
  pin          String?
  role         Role            @default(CLIENT)
  status       EmployeeStatus  @default(ACTIVE)
  isOnShift    Boolean         @default(false)
  fixedSalary  Decimal         @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  shifts       Shift[]
  sales        Sale[]
  routes       DeliveryRoute[]
  vehicles     Vehicle[]       @relation("DriverVehicle")
  
  // Baker/Courier workspace relations
  productionBatches ProductionBatch[]
  defects           DefectLog[]
  deliveryOrders    DeliveryOrder[]

  // Client workspace relation
  clientId     Int?            @unique
  client       Client?         @relation(fields: [clientId], references: [id])

  // Expenses & Incomes relation
  expenses     Expense[]
  incomes      Income[]
}

// ─── Categories ─────────────────────────────────────────

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  iconName  String    @default("Flame")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

// ─── Products ───────────────────────────────────────────

model Product {
  id         Int       @id @default(autoincrement())
  sku        String    @unique
  name       String
  categoryId Int
  weight     Int       @default(0)
  cost       Float     @default(0)
  price      Float     @default(0)
  isActive   Boolean   @default(true)
  imageUrl   String?
  isHit      Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category   Category  @relation(fields: [categoryId], references: [id])

  orderItems      OrderItem[]
  saleItems       SaleItem[]
  loadItems       LoadItem[]
  recipe          Recipe?
  productionTasks ProductionTask[]
  
  // Baker/Courier workspace relations
  productionBatches ProductionBatch[]
  defects           DefectLog[]
  deliveryOrderItems DeliveryOrderItem[]
  stock             Int             @default(0) // Showcase stock (На витрине)
}

// ─── Clients ────────────────────────────────────────────

model Client {
  id           Int       @id @default(autoincrement())
  name         String
  type         String    @default("Магазин у дома")
  ownerName    String?
  phone        String?
  email        String?
  route        String?
  balance      Float     @default(0)
  deliveryTime String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders       Order[]
  routePoints  RoutePoint[]
  user         User?
  deliveryOrders DeliveryOrder[]
  payments     ClientPayment[]
}

// ─── Client Requests ────────────────────────────────────

model ClientRequest {
  id           Int           @id @default(autoincrement())
  clientName   String
  clientType   String        @default("Магазин")
  phone        String
  contactName  String
  address      String
  deliveryTime String?
  comment      String?
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ─── Orders ─────────────────────────────────────────────

model Order {
  id           Int          @id @default(autoincrement())
  clientId     Int
  deliveryDate DateTime     @default(now())
  deliveryTime String?
  status       OrderStatus  @default(NEW)
  total        Float        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client       Client       @relation(fields: [clientId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int     @default(1)
  price     Float   @default(0)

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Delivery Routes ────────────────────────────────────

model DeliveryRoute {
  id        Int          @id @default(autoincrement())
  name      String
  driverId  Int?
  status    RouteStatus  @default(BUILDING)
  date      DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  driver    User?        @relation(fields: [driverId], references: [id])
  points    RoutePoint[]
  loadItems LoadItem[]
}

model RoutePoint {
  id        Int          @id @default(autoincrement())
  routeId   Int
  clientId  Int?
  storeName String
  time      String?
  totalSum  Float        @default(0)
  status    PointStatus  @default(PENDING)
  sortOrder Int          @default(0)

  route     DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  client    Client?       @relation(fields: [clientId], references: [id])
}

model LoadItem {
  id        Int           @id @default(autoincrement())
  routeId   Int
  productId Int
  quantity  Int           @default(0)

  route     DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])
}

// ─── Raw Materials Stock & Recipes ─────────────────────────

model RawMaterial {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  unit        String   @default("г") // Base unit, always stored in this unit (e.g., grams)
  costPerUnit Decimal  @default(0)   // Cost per 1 base unit
  stock       Decimal  @default(0)   // Current stock in base units
  minLimit    Decimal  @default(0)   // Minimum required stock before alert
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  recipeIngredients  RecipeIngredient[]
  purchaseItems      PurchaseItem[]
  adjustments        InventoryAdjustment[]
}

// ─── Inventory Adjustments (Сверка/Порча) ───────────────

model InventoryAdjustment {
  id            Int            @id @default(autoincrement())
  rawMaterialId Int
  type          AdjustmentType @default(AUDIT)
  amount        Decimal        // The difference (e.g. -5000 grams)
  reason        String?
  expenseId     Int?
  createdAt     DateTime       @default(now())

  rawMaterial   RawMaterial    @relation(fields: [rawMaterialId], references: [id])
  expense       Expense?       @relation(fields: [expenseId], references: [id])
}

// ─── Recipes ────────────────────────────────────────────

model Recipe {
  id        Int                @id @default(autoincrement())
  productId Int                @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  product     Product          @relation(fields: [productId], references: [id])
  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id            Int         @id @default(autoincrement())
  recipeId      Int
  rawMaterialId Int
  amount        Decimal     @default(0)
  quantity      Decimal     @default(0) // Quantity of raw material for 1 item (for baker)

  recipe        Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
}

// ─── Purchases ──────────────────────────────────────────

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  phone     String?
  balance   Decimal   @default(0) // Debt to supplier
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchases Purchase[]
  payments  SupplierPayment[]
}

model SupplierPayment {
  id         Int      @id @default(autoincrement())
  supplierId Int
  amount     Decimal
  date       DateTime @default(now())
  expenseId  Int?

  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  expense    Expense? @relation(fields: [expenseId], references: [id])
}

model Purchase {
  id            Int             @id @default(autoincrement())
  date          DateTime        @default(now())
  supplierId    Int?
  invoiceNumber String?
  totalSum      Decimal         @default(0)
  status        PurchaseStatus  @default(IN_TRANSIT)
  paymentStatus PaymentStatus   @default(UNPAID)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]
}

model PurchaseItem {
  id              Int           @id @default(autoincrement())
  purchaseId      Int
  rawMaterialId   Int
  name            String
  orderedQty      Decimal       @default(0) // Quantity in base unit (grams)
  unit            String        @default("г")
  price           Decimal       @default(0) // Price for this item

  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial   @relation(fields: [rawMaterialId], references: [id])
}

// ─── Expenses ───────────────────────────────────────────

model Expense {
  id            Int              @id @default(autoincrement())
  date          DateTime         @default(now())
  category      ExpenseCategory  @default(OTHER)
  description   String?
  paymentMethod PaymentMethod    @default(CASH)
  amount        Decimal          @default(0)
  isAuto        Boolean          @default(false)
  vehicleId     Int?
  userId        Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  adjustments   InventoryAdjustment[]
  supplierPayments SupplierPayment[]
  vehicle       Vehicle?         @relation(fields: [vehicleId], references: [id])
  user          User?            @relation(fields: [userId], references: [id])
}

// ─── Incomes & Client Payments ──────────────────────────

model ClientPayment {
  id            Int           @id @default(autoincrement())
  clientId      Int
  amount        Decimal
  date          DateTime      @default(now())
  paymentMethod PaymentMethod @default(KASPI)
  incomeId      Int?          @unique

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  income        Income?       @relation(fields: [incomeId], references: [id])
}

model Income {
  id            Int             @id @default(autoincrement())
  date          DateTime        @default(now())
  source        IncomeSource    @default(MANUAL)
  description   String?
  paymentMethod PaymentMethod   @default(CASH)
  amount        Decimal         @default(0)
  isAuto        Boolean         @default(false)
  userId        Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?           @relation(fields: [userId], references: [id])
  clientPayment ClientPayment?
}


// ─── Vehicles (Fleet) ───────────────────────────────────

model Vehicle {
  id              Int            @id @default(autoincrement())
  brandModel      String
  licensePlate    String         @unique
  capacityTrays   Int            @default(0)
  driverId        Int?
  status          VehicleStatus  @default(ACTIVE)
  fuelConsumption Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  driver          User?          @relation("DriverVehicle", fields: [driverId], references: [id])
  expenses        Expense[]
}

// ─── Roles & Permissions ────────────────────────────────

model CustomRole {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  permissions RolePermission[]
}

model RolePermission {
  id         Int        @id @default(autoincrement())
  roleId     Int
  module     String
  canView    Boolean    @default(false)
  canCreate  Boolean    @default(false)
  canEdit    Boolean    @default(false)
  canDelete  Boolean    @default(false)

  role       CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}

// ─── Production ─────────────────────────────────────────

model ProductionTask {
  id        Int      @id @default(autoincrement())
  productId Int
  planned   Int      @default(0)
  completed Int      @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  batches   BatchLog[]
}

model BatchLog {
  id          Int            @id @default(autoincrement())
  taskId      Int
  time        String
  productName String
  quantity    Int            @default(0)
  type        BatchType      @default(READY)
  createdAt   DateTime       @default(now())

  task        ProductionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── POS (Point of Sale) ────────────────────────────────

model Shift {
  id         Int       @id @default(autoincrement())
  userId     Int
  startCash  Float     @default(0)
  endCash    Float?
  isOpen     Boolean   @default(true)
  openedAt   DateTime  @default(now())
  closedAt   DateTime?

  user       User      @relation(fields: [userId], references: [id])
  sales      Sale[]
}

model Sale {
  id            Int           @id @default(autoincrement())
  shiftId       Int
  userId        Int
  total         Float         @default(0)
  paymentMethod PaymentMethod @default(CASH)
  createdAt     DateTime      @default(now())

  shift         Shift         @relation(fields: [shiftId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int     @default(1)
  price     Float   @default(0)

  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Baker Workspace Models ─────────────────────────────

model ProductionBatch {
  id          Int         @id @default(autoincrement())
  productId   Int
  product     Product     @relation(fields: [productId], references: [id])
  quantity    Int
  status      BatchStatus @default(IN_PROGRESS)
  bakerId     Int
  baker       User        @relation(fields: [bakerId], references: [id])
  startTime   DateTime    @default(now())
  endTime     DateTime?
}

model DefectLog {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  reason      String?
  bakerId     Int
  baker       User     @relation(fields: [bakerId], references: [id])
  createdAt   DateTime @default(now())
}

// ─── Courier Workspace Models ───────────────────────────

model DeliveryOrder {
  id            Int                 @id @default(autoincrement())
  clientName    String
  clientPhone   String
  address       String
  status        DeliveryOrderStatus @default(PENDING)
  totalAmount   Int
  isPaid        Boolean             @default(false)
  isBaked       Boolean             @default(false)
  paymentMethod String?             // "CASH", "CARD", "QR", "DEBT"
  driverId      Int?
  driver        User?               @relation(fields: [driverId], references: [id])
  clientId      Int?
  client        Client?             @relation(fields: [clientId], references: [id])
  createdAt     DateTime            @default(now())
  items         DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id        Int           @id @default(autoincrement())
  orderId   Int
  order     DeliveryOrder @relation(fields: [orderId], references: [id])
  productId Int
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int           // Price per unit at the time of sale
}
