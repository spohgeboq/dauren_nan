{
  "name": "daurennan-crm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "cross-env VITE_APP_SURFACE=desktop vite",
    "dev:pos-desktop": "cross-env VITE_APP_SURFACE=pos-desktop vite",
    "dev:mobile": "cross-env VITE_APP_SURFACE=mobile vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "build:web": "cross-env VITE_APP_SURFACE=web npm run build",
    "build:desktop": "cross-env VITE_APP_SURFACE=desktop npm run build",
    "build:pos-desktop": "cross-env VITE_APP_SURFACE=pos-desktop npm run build",
    "build:mobile": "cross-env VITE_APP_SURFACE=mobile npm run build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env VITE_APP_SURFACE=desktop vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 VITE_APP_SURFACE=desktop electron .\"",
    "electron:dev:pos": "concurrently -k \"cross-env VITE_APP_SURFACE=pos-desktop vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 VITE_APP_SURFACE=pos-desktop electron .\"",
    "electron:pack": "npm run build:desktop && electron-builder --dir",
    "electron:dist": "npm run build:desktop && electron-builder",
    "electron:dist:pos": "npm run build:pos-desktop && cross-env APP_SURFACE=pos-desktop electron-builder",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "axios": "^1.18.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.475.0",
    "maska": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "description": "Bakery ERP frontend reconstructed in React + Vite",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
