# ============================================================
# Конфигурация фронтенда для работы через ngrok
# ============================================================
# 
# ИНСТРУКЦИЯ:
# 1. Запустите бэкенд: cd backend && npm run dev
# 2. Запустите ngrok: ngrok http 5000
# 3. Скопируйте https URL из ngrok (например: https://abcd-1234.ngrok-free.app)
# 4. Вставьте его ниже, добавив /api в конце
# 5. Пересоберите/перезапустите фронтенд
#
# ============================================================

# URL бэкенда через ngrok (ЗАМЕНИТЕ на ваш реальный URL!)
# Пример: VITE_API_URL=https://abcd-1234.ngrok-free.app/api
VITE_API_URL=http://localhost:5000/api
